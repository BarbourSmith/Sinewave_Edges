      "interpreterVersion": 1,
      "code": "/**\n * Sine-Wave Edge\n *\n * Takes a 2D shape (e.g. a circle) and displaces its outline in and out along\n * the local outward normal following a sine wave. The result is the same shape\n * with a wavy, scalloped edge.\n *\n * The wave is parametrised by true arc length around the perimeter, so the\n * period and amplitude are constant in millimetres regardless of the shape.\n * Because the perimeter is generally not an exact multiple of the period, the\n * wave cannot meet itself smoothly — that single discontinuity (the \"seam\") is\n * forced to the bottom of the shape, i.e. the -y direction.\n *\n * @param shape     A 2D geometry to add the wavy edge to (wire from another atom)\n * @param period    Wavelength of the sine wave along the edge, in mm\n * @param amplitude Peak in/out displacement of the edge, in mm\n */\nfunction run(\n  shape: Assembly | undefined = undefined,\n  period: number = 10,\n  amplitude: number = 2,\n): Assembly {\n  if (!shape) {\n    throw new Error(\"Connect a 2D shape to the 'shape' input.\");\n  }\n\n  const per = Math.max(period, 1e-6); // guard against divide-by-zero\n\n  // Turn one flat replicad Drawing into a wavy-edged Drawing.\n  const makeWavy = (drawing: any): any => {\n    // Get the outline of the shape as a single closed wire.\n    const sketch = drawing.sketchOnPlane();\n    const wire = sketch.face().outerWire();\n    const perimeter = wire.length;\n\n    // Sample the outline densely enough to resolve every wave crest.\n    const pointsPerPeriod = 32;\n    let n = Math.ceil((perimeter / per) * pointsPerPeriod);\n    n = Math.max(120, Math.min(n, 6000));\n\n    // pointAt() takes a normalised parameter 0..1 around the closed wire.\n    // We stop before 1.0 so we don't duplicate the start point.\n    const raw: { x: number; y: number }[] = [];\n    for (let i = 0; i < n; i++) {\n      const v = wire.pointAt(i / n);\n      raw.push({ x: v.x, y: v.y });\n    }\n\n    // Rotate the sample list so it starts at the bottom-most point. This puts\n    // the wave's seam (where it wraps and must jump) in the -y direction.\n    let startIdx = 0;\n    let minY = Infinity;\n    for (let i = 0; i < n; i++) {\n      if (raw[i].y < minY) {\n        minY = raw[i].y;\n        startIdx = i;\n      }\n    }\n    const pts = raw.slice(startIdx).concat(raw.slice(0, startIdx));\n\n    // Winding order (signed area) tells us which normal direction is \"outward\".\n    let area2 = 0;\n    for (let i = 0; i < n; i++) {\n      const a = pts[i];\n      const b = pts[(i + 1) % n];\n      area2 += a.x * b.y - b.x * a.y;\n    }\n    const ccw = area2 > 0;\n\n    // Cumulative arc length from the seam, used to drive the sine phase.\n    const s = new Array<number>(n);\n    s[0] = 0;\n    for (let i = 1; i < n; i++) {\n      s[i] = s[i - 1] + Math.hypot(pts[i].x - pts[i - 1].x, pts[i].y - pts[i - 1].y);\n    }\n\n    // Displace each point along its outward normal by amplitude * sin(2π·s/λ).\n    const out: [number, number][] = [];\n    for (let i = 0; i < n; i++) {\n      const prev = pts[(i - 1 + n) % n];\n      const next = pts[(i + 1) % n];\n      let tx = next.x - prev.x;\n      let ty = next.y - prev.y;\n      const tl = Math.hypot(tx, ty) || 1;\n      tx /= tl;\n      ty /= tl;\n\n      // Rotate the tangent 90° to the exterior side of the curve.\n      const nx = ccw ? ty : -ty;\n      const ny = ccw ? -tx : tx;\n\n      const disp = amplitude * Math.sin((2 * Math.PI * s[i]) / per);\n      out.push([pts[i].x + nx * disp, pts[i].y + ny * disp]);\n    }\n\n    // Rebuild the closed 2D outline. The seam is out[n-1] -> out[0] at the\n    // bottom, where the displacement returns to 0 so the jump is clean.\n    let pen = replicad.draw(out[0]);\n    for (let i = 1; i < out.length; i++) {\n      pen = pen.lineTo(out[i]);\n    }\n    return pen.close();\n  };\n\n  // Apply to every 2D leaf in the input, leaving anything non-2D untouched.\n  const result = new Assembly(shape);\n  result.onLeafs((leaf) => {\n    const g = leaf.geometry;\n    if (g && typeof g.sketchOnPlane === \"function\") {\n      leaf.geometry = makeWavy(g);\n      leaf.tags = [...(leaf.tags ?? []), \"sine-wave-edge\"];\n    }\n    return leaf;\n  });\n\n  return result;\n}",
      "compiledCode": "\"use strict\";\n/**\n * Sine-Wave Edge\n *\n * Takes a 2D shape (e.g. a circle) and displaces its outline in and out along\n * the local outward normal following a sine wave. The result is the same shape\n * with a wavy, scalloped edge.\n *\n * The wave is parametrised by true arc length around the perimeter, so the\n * period and amplitude are constant in millimetres regardless of the shape.\n * Because the perimeter is generally not an exact multiple of the period, the\n * wave cannot meet itself smoothly — that single discontinuity (the \"seam\") is\n * forced to the bottom of the shape, i.e. the -y direction.\n *\n * @param shape     A 2D geometry to add the wavy edge to (wire from another atom)\n * @param period    Wavelength of the sine wave along the edge, in mm\n * @param amplitude Peak in/out displacement of the edge, in mm\n */\nfunction run(shape = undefined, period = 10, amplitude = 2) {\n    if (!shape) {\n        throw new Error(\"Connect a 2D shape to the 'shape' input.\");\n    }\n    const per = Math.max(period, 1e-6); // guard against divide-by-zero\n    // Turn one flat replicad Drawing into a wavy-edged Drawing.\n    const makeWavy = (drawing) => {\n        // Get the outline of the shape as a single closed wire.\n        const sketch = drawing.sketchOnPlane();\n        const wire = sketch.face().outerWire();\n        const perimeter = wire.length;\n        // Sample the outline densely enough to resolve every wave crest.\n        const pointsPerPeriod = 32;\n        let n = Math.ceil((perimeter / per) * pointsPerPeriod);\n        n = Math.max(120, Math.min(n, 6000));\n        // pointAt() takes a normalised parameter 0..1 around the closed wire.\n        // We stop before 1.0 so we don't duplicate the start point.\n        const raw = [];\n        for (let i = 0; i < n; i++) {\n            const v = wire.pointAt(i / n);\n            raw.push({ x: v.x, y: v.y });\n        }\n        // Rotate the sample list so it starts at the bottom-most point. This puts\n        // the wave's seam (where it wraps and must jump) in the -y direction.\n        let startIdx = 0;\n        let minY = Infinity;\n        for (let i = 0; i < n; i++) {\n            if (raw[i].y < minY) {\n                minY = raw[i].y;\n                startIdx = i;\n            }\n        }\n        const pts = raw.slice(startIdx).concat(raw.slice(0, startIdx));\n        // Winding order (signed area) tells us which normal direction is \"outward\".\n        let area2 = 0;\n        for (let i = 0; i < n; i++) {\n            const a = pts[i];\n            const b = pts[(i + 1) % n];\n            area2 += a.x * b.y - b.x * a.y;\n        }\n        const ccw = area2 > 0;\n        // Cumulative arc length from the seam, used to drive the sine phase.\n        const s = new Array(n);\n        s[0] = 0;\n        for (let i = 1; i < n; i++) {\n            s[i] = s[i - 1] + Math.hypot(pts[i].x - pts[i - 1].x, pts[i].y - pts[i - 1].y);\n        }\n        // Displace each point along its outward normal by amplitude * sin(2π·s/λ).\n        const out = [];\n        for (let i = 0; i < n; i++) {\n            const prev = pts[(i - 1 + n) % n];\n            const next = pts[(i + 1) % n];\n            let tx = next.x - prev.x;\n            let ty = next.y - prev.y;\n            const tl = Math.hypot(tx, ty) || 1;\n            tx /= tl;\n            ty /= tl;\n            // Rotate the tangent 90° to the exterior side of the curve.\n            const nx = ccw ? ty : -ty;\n            const ny = ccw ? -tx : tx;\n            const disp = amplitude * Math.sin((2 * Math.PI * s[i]) / per);\n            out.push([pts[i].x + nx * disp, pts[i].y + ny * disp]);\n        }\n        // Rebuild the closed 2D outline. The seam is out[n-1] -> out[0] at the\n        // bottom, where the displacement returns to 0 so the jump is clean.\n        let pen = replicad.draw(out[0]);\n        for (let i = 1; i < out.length; i++) {\n            pen = pen.lineTo(out[i]);\n        }\n        return pen.close();\n    };\n    // Apply to every 2D leaf in the input, leaving anything non-2D untouched.\n    const result = new Assembly(shape);\n    result.onLeafs((leaf) => {\n        const g = leaf.geometry;\n        if (g && typeof g.sketchOnPlane === \"function\") {\n            leaf.geometry = makeWavy(g);\n            leaf.tags = [...(leaf.tags ?? []), \"sine-wave-edge\"];\n        }\n        return leaf;\n    });\n    return result;\n}\n"
    },
